amends "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["eslint"] = (Builtins.eslint) {
    glob = List("*.js", "*.jsx", "*.ts", "*.tsx", "*.mjs")
  }
  ["trailing_whitespace"] = Builtins.trailing_whitespace
  ["mixed_line_ending"] = Builtins.mixed_line_ending
  ["check_merge_conflict"] = Builtins.check_merge_conflict
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps {
      ...linters
      ["tsc"] = Builtins.tsc
    }
  }
  ["check"] {
    steps {
      ...linters
      ["tsc"] = Builtins.tsc
    }
  }
}
